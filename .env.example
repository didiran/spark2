# Spark-Kafka ML Training Pipeline - Environment Variables
# Copy this file to .env and adjust values for your environment.

# Pipeline
PIPELINE_ENV=development
LOG_LEVEL=INFO

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Spark
SPARK_MASTER_URL=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ml_pipeline
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=changeme

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=spark-ml-training

# Storage
DELTA_BASE_PATH=/data/delta
FEATURE_STORE_PATH=/data/delta/feature_store
MODEL_ARTIFACTS_PATH=/data/models
